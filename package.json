# server
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-secret-key

# use this if you are deploying to render with aiven mysql
# example format: mysql://avnadmin:password@your-host.aivencloud.com:12345/defaultdb
DATABASE_URL=
DB_SSL=true

# optional individual mysql values if you do not want to use DATABASE_URL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=defaultdb

# automatic table creation and seed admin account
AUTO_MIGRATE=true
ADMIN_NAME=Ruthy's Admin
ADMIN_EMAIL=admin@ruthys.com
ADMIN_PASSWORD=admin12345
